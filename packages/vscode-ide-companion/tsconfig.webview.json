{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/webview/*": ["./src/webview/*"]
    }
  },
  "include": ["src/webview/**/*.ts", "src/webview/**/*.tsx"],
  "exclude": ["node_modules", "src/webview/**/*.test.ts", "src/webview/**/*.test.tsx"]
}
